  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/preact": "^3.2.4",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.8"
  }
}
