{
  "name": "gosite-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "GoSite control panel frontend — lightweight, stateless Preact SPA.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
